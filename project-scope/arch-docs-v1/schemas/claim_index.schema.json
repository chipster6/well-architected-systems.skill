{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["claims"],
  "properties": {
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "class", "statement"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "class": {
            "type": "string",
            "enum": ["source-backed", "decision", "assumption"]
          },
          "statement": { "type": "string" },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^MCP-\\d{8}-\\d{4}$"
            }
          },
          "adr_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
